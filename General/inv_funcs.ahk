tossItem(iid, icount := "")
{
    BlockInput, on
    items := initItems()
    slot := -1
    page := -1
    desciption := ""
    ;AddChatMessage(items.MaxIndex())
    If (iid > items.MaxIndex() OR iid < items.MinIndex())
    {
        AddChatMessage("Ungültige Item-ID")
        SendInput, {Esc}
        BlockInput, off
        Return
    }
    SendChat("/inventar")
    sleep 100
    SendInput, {Enter}
    sleep 100
    y := GetDialogLines()
    for index, element in y
    if (InStr(element, items[iid]))
    {
        page := 1
        slot := index
        desciption := element
        Break
    }
    else
    { 
    SendInput {Down}
    SendInput {Enter}
    Sleep 100
    z := GetDialogLines()
    for index, element in z
    if (InStr(element, items[iid]))
    {
        page := 2
        slot := index
        desciption := element
    }
    ;AddChatMessage(page " - " slot " - " desciption)
    }
    if (page = -1)
    {
        AddChatMessage("Dieses Item besizt du nicht!")
        SendInput, {Esc}
        BlockInput, off
        Return
    }
    if (page = 1)
    {
        SendInput, {Enter}
        Sleep 100
    }
    ;%slot-1%
    dn := slot-1
    SendInput, {Down %dn%}
    sleep 20
    SendInput {Enter}
    Sleep 100
    SendInput {Down 2}
    sleep 20
    SendInput {Enter}
    Sleep 100
    if (icount >= 0)
    {
        RegExMatch(desciption, "\(\d*\)", gggg)
        StringLeft, gg, gggg, 1
        StringRight, gg, gg, 1
        If (icount > gg)
        {
            icount := 999999
        }
    }
    If (icount = "")
    {
       icount := 999999 
    }
    SendRaw %icount%
    sleep 20
    SendInput, {enter}
        sleep 20
    SendInput, {Esc}
        sleep 20
    SendInput, {Esc}

    BlockInput, off
Return
}
Return

transferItemFromPlayerInventroy(iid, typ, icount := "" , pid := "")
{
    /*
    Typ: 0 -> To player  (tranfers to GetClosestPlayerId() if empty)
    1 -> VEH (if IsPlayerInAnyVehicle() // /VEH)
    2 -> House (if GetPlayerInteriorId())
    3 -> PostOffice (if IsPlayerInRangeOfPoint() returns true) - not in Beta
    4 -> Fraction
    5 -> Appartment 
    */
    If (typ > 5 or typ < 0)
    {
        AddChatMessage("Falscher Typ")
        Return
    }
    If (typ = 0 )
    {
        If (pid = "")
        {
            /*AddChatMessage("Spieler ID darf nicht leer sein!")
            Return
            */
            pid := GetClosestPlayerId()
            if (pid = -1)
            {
                AddChatMessage("Spieler nicht gefunden!")
                Return
            }
        }
        If pid is Not digit
        {
            AddChatMessage("Spieler ID Ungültig")
            Return

        }
        if (isNPCById(pid))
        {
            AddChatMessage("Spieler ID darf kein NPC sein")
            Return
        }
    }
If (typ = 1 )
    {
        If (!IsPlayerDriver())
        {
            AddChatMessage("Du kannst diese Funktion nur als Fahrer verwenden!")
            Return
        }
        Else
        {
            SendChat("/veh")
            Sleep, 50
            SendInput, {Enter}
            sleep 50
            GetChatLine(0,chat)
            If (InStr(chat, "Kofferraum verschlossen"))
            {
                SendChat("/veh")
                Sleep, 50
                SendInput, {Enter}
                sleep 50   
            }
        }
    }
    If (typ = 2 )
    {
        If (GetPlayerInteriorId() = 0)
        {
            AddChatMessage("Du kannst diese Funktion nur in einem Interior nutzen")
            Return
        }
    }


    BlockInput, on
    items := initItems()
    slot := -1
    page := -1
    desciption := ""
    ;AddChatMessage(items.MaxIndex())
    If (iid > items.MaxIndex() OR iid < items.MinIndex())
    {
        AddChatMessage("Ungültige Item-ID")
        SendInput, {Esc}
        BlockInput, off
        Return
    }
    SendChat("/inventar")
    sleep 100
    SendInput, {Enter}
    sleep 100
    y := GetDialogLines()
    for index, element in y
    if (InStr(element, items[iid]))
    {
        page := 1
        slot := index
        desciption := element
        Break
    }
    else
    { 
    SendInput {Down}
    SendInput {Enter}
    Sleep 100
    z := GetDialogLines()
    for index, element in z
    if (InStr(element, items[iid]))
    {
        page := 2
        slot := index
        desciption := element
        Break
    }
    ;AddChatMessage(page " - " slot " - " desciption)
    }
    if (page = -1)
    {
        AddChatMessage("Dieses Item besizt du nicht!")
        SendInput, {Esc}
        BlockInput, off
        Return
    }
    if (page = 1)
    {
        SendInput, {Enter}
        Sleep 100
    }
    ;%slot-1%
    dn := slot-1
    SendInput, {Down %dn%}
    sleep 20
    SendInput {Enter}
    Sleep 100
    SendInput {Down 3}
    sleep 20
    SendInput {Enter}
    Sleep 100
    if (icount <= 0 or icount = "")
    {
        RegExMatch(desciption, "\(\d*\)", gggg)
        StringLeft, gg, gggg, 1
        StringRight, gg, gg, 1
        If (icount > gg)
        {
            icount := %gg%
        }
    }
    if (typ = 0)
    {
        SendInput, {Enter}
        Sleep, 100
        SendRaw %pid%
        Sleep, 50
        SendInput, {Enter}
        Sleep, 100
    }
    Else
    {
        SendInput, {Down %typ%}
        sleep 20
        SendInput, {Enter}
        Sleep, 100
    }
    SendRaw %icount%
    sleep 20
    SendInput, {enter}
        sleep 50
    SendInput, {Esc}
        sleep 50
    SendInput, {Esc}
    BlockInput, off
Return
}
